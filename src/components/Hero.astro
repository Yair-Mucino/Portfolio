---
import GitHubIcon from "@/components/icons/GitHub.astro";
import LinkedInIcon from "@/components/icons/LinkedIn.astro";
import MailIcon from "@/components/icons/Mail.astro";
import SocialPill from "@/components/SocialPill.astro";
---

<section
  class="mx-auto max-w-4xl px-4 pt-32 pb-16"
  id="inicio"
  aria-label="Presentación"
>
  <div class="flex flex-col items-start">
    <h1
      class="anim-fade-in anim-delay-1 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl dark:text-white"
    >
      Hola, soy <span class="gradient-name">Yair</span>
    </h1>

    <p
      class="anim-fade-in anim-delay-2 mt-6 max-w-3xl text-xl leading-relaxed text-slate-700 dark:text-slate-300 [&>strong]:font-semibold [&>strong]:text-cyan-600 dark:[&>strong]:text-cyan-300"
    >
      +1 año de experiencia.
      <strong>
        Ingeniero en Software apasionado por la tecnología y el desarrollo de
        soluciones innovadoras.
      </strong>
      Actualmente continúo fortaleciendo mis habilidades a través de proyectos,
      nuevas herramientas y buenas prácticas de desarrollo.
    </p>

    <nav
      class="anim-fade-in anim-delay-3 mt-8 flex flex-wrap gap-4"
      aria-label="Redes sociales y contacto"
    >
      <SocialPill href="mailto:yairsm20@gmail.com">
        <MailIcon class="size-4" />
        Contáctame
      </SocialPill>

      <SocialPill href="https://linkedin.com/in/yair-mucino">
        <LinkedInIcon class="size-4" />
        LinkedIn
      </SocialPill>

      <SocialPill href="https://github.com/Yair-Mucino">
        <GitHubIcon class="size-4" />
        GitHub
      </SocialPill>
    </nav>
  </div>
</section>