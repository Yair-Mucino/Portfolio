---
const { href } = Astro.props;
---

<a
  target="_blank"
  href={href}
  class="
    inline-flex
    items-center
    gap-2
    px-3
    py-1.5
    text-sm
    font-medium
    rounded-full

    bg-slate-100/80
    dark:bg-slate-900/50

    border
    border-slate-300/60
    dark:border-slate-700

    text-slate-700
    dark:text-slate-200

    transition-all
    duration-300

    hover:border-cyan-400/50
    hover:text-cyan-500
    hover:-translate-y-0.5

    focus:outline-none
    focus-visible:ring-2
    focus-visible:ring-cyan-500/50
    "
    >
  <slot />
</a>