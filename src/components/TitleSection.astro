---
const { className } = Astro.props;
---

<div class="mb-8">
  <h2
    class={`flex items-center gap-x-3 text-3xl font-bold tracking-tight text-slate-900 dark:text-white ${className ?? ""}`}
  >
    <slot />
  </h2>

  <div
    class="mt-3 h-1 w-14 rounded-full bg-cyan-500"
    aria-hidden="true"
  ></div>
</div>