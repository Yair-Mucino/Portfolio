---
import GitHub from "./icons/GitHub.astro";
import NextJS from "./icons/NextJS.astro";
import Tailwind from "./icons/Tailwind.astro";
import React from "./icons/React.astro";
import JavaScript from "./icons/JavaScript.astro";
import PostgreSQL from "./icons/PostgreSQL.astro";
import CSharp from "./icons/Csharp.astro";
import WPF from "./icons/WPF.astro";
import MySQL from "./icons/MySQL.astro";
import Unity from "./icons/Unity.astro";
import Blender from "./icons/Blender.astro";
import ExternalLink from "./icons/ExternalLink.astro";
import LinkButton from "./LinkButton.astro";
import projectsData from "@/data/projects.json";

const TAGS: Record<string, { name: string; class: string; icon: any }> = {
  NEXT: {
    name: "Next.js",
    class: "bg-slate-950 text-white dark:bg-white dark:text-slate-950",
    icon: NextJS,
  },
  REACT: {
    name: "React",
    class: "bg-sky-100 text-sky-700 dark:bg-sky-900/40 dark:text-sky-300",
    icon: React,
  },
  TAILWIND: {
    name: "Tailwind CSS",
    class: "bg-cyan-100 text-cyan-700 dark:bg-cyan-900/40 dark:text-cyan-300",
    icon: Tailwind,
  },
  JAVASCRIPT: {
    name: "JavaScript",
    class: "bg-yellow-100 text-yellow-700 dark:bg-yellow-900/40 dark:text-yellow-300",
    icon: JavaScript,
  },
  POSTGRESQL: {
    name: "PostgreSQL",
    class: "bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300",
    icon: PostgreSQL,
  },
  CSHARP: {
    name: "C#",
    class: "bg-violet-100 text-violet-700 dark:bg-violet-900/40 dark:text-violet-300",
    icon: CSharp,
  },
  WPF: {
    name: "WPF",
    class: "bg-indigo-100 text-indigo-700 dark:bg-indigo-900/40 dark:text-indigo-300",
    icon: WPF,
  },
  MYSQL: {
    name: "MySQL",
    class: "bg-sky-100 text-sky-800 dark:bg-sky-900/40 dark:text-sky-300",
    icon: MySQL,
  },
  UNITY: {
  name: "Unity",
  class: "bg-zinc-100 text-zinc-800 dark:bg-zinc-900/40 dark:text-zinc-300",
  icon: Unity,
  },
  BLENDER: {
  name: "Blender",
  class: "bg-orange-100 text-orange-700 dark:bg-orange-900/40 dark:text-orange-300",
  icon: Blender,
  },
};

const PROJECTS = projectsData.map((project) => ({
  ...project,
  tags: project.tags
    .map((key) => TAGS[key])
    .filter(Boolean),
}));
---

<div class="flex flex-col gap-y-16">
  {
    PROJECTS.map(({ image, title, description, tags, github }) => (
      <article class="group flex flex-col space-y-6 md:flex-row md:space-x-10 md:space-y-0">
        <div class="w-full md:w-1/2">
          <div class="relative col-span-6 row-span-5 flex flex-col items-center gap-8 overflow-clip rounded-2xl border border-slate-200/70 shadow-xl shadow-slate-900/5 transition-all duration-500 ease-in-out md:group-hover:-translate-y-1 md:group-hover:shadow-[0_20px_60px_-10px_rgba(6,182,212,0.22)] dark:border-slate-800 dark:bg-slate-900/40 lg:hover:border-cyan-400/30">
            <img
              alt={title}
              class="h-56 w-full object-cover object-top transition duration-500 sm:h-full md:scale-105 md:group-hover:scale-100"
              loading="lazy"
              src={image}
            />

            <div
              class="pointer-events-none absolute inset-0 bg-gradient-to-t from-cyan-950/40 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"
              aria-hidden="true"
            />
          </div>
        </div>

        <div class="flex w-full flex-col justify-center md:w-1/2 md:max-w-lg">
          <h3 class="text-2xl font-bold text-slate-900 dark:text-slate-100">
            {title}
          </h3>

          <ul class="mt-3 flex flex-row flex-wrap gap-2">
            {tags.map((tag) => (
              <li>
                <span class={`flex items-center gap-x-2 rounded-full px-2.5 py-1 text-xs font-medium ${tag.class}`}>
                  <tag.icon class="size-4" />
                  {tag.name}
                </span>
              </li>
            ))}
          </ul>

          <p class="mt-3 text-pretty text-slate-700 dark:text-slate-400">
            {description}
          </p>

          <footer class="mt-4 flex items-center gap-x-4">
            {github && (
              <LinkButton href={github}>
                <GitHub class="size-4" />
                Código
              </LinkButton>
            )}
          </footer>
        </div>
      </article>
    ))
  }
</div>